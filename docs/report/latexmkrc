# latexmkrc configuration

# Default output directory
$out_dir = 'out';

# Default compile mode: PDF using pdflatex
$pdf_mode = 1;

# Disable viewer for watch mode (headless container)
$view = 'none';

# Automatically create the output directory structure inside "out"
use File::Path qw(make_path);
make_path('out/chapters');
