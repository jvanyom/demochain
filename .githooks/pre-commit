#!/bin/bash

# Runs ruff on staged Python files (voting-contract/)
# Runs oxlint + oxfmt on staged TS/JS files (client/)

failed=0

# --- Python (voting-contract/) ---
staged_py=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$')

if [[ -n "$staged_py" ]]; then
  if ! command -v ruff &>/dev/null; then
    echo "⚠️  ruff no trobat - saltant la comprovació de Python."
    echo "   Instal·la'l amb: pip install ruff"
  else
    echo "🔍 Comprovant Python amb ruff..."
    echo "$staged_py" | xargs ruff check --fix --quiet
    echo "$staged_py" | xargs ruff format --quiet
    echo "$staged_py" | xargs git add
    if ! echo "$staged_py" | xargs ruff check --quiet; then
      echo "❌ ruff ha trobat errors que no s'han pogut corregir automàticament."
      echo "   Executa 'make fmt-contract' per veure els detalls."
      failed=1
    fi
  fi
fi

# --- TypeScript / JavaScript (client/) ---
staged_ts=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$')

if [[ -n "$staged_ts" ]]; then
  if [[ ! -d "client" ]]; then
    echo "⚠️  Directori client/ no trobat - saltant la comprovació de TypeScript."
  elif ! (cd client && bunx oxlint --version &>/dev/null 2>&1); then
    echo "⚠️  oxlint no trobat - saltant la comprovació de TypeScript."
    echo "   Instal·la'l amb: cd client && bun install"
  else
    echo "🔍 Comprovant TypeScript amb oxlint + oxfmt..."
    ts_files_rel=$(echo "$staged_ts" | sed 's|^client/||' | grep -v '^scripts/')
    if [[ -n "$ts_files_rel" ]]; then
      (cd client && echo "$ts_files_rel" | xargs bunx oxfmt 2>/dev/null)
      echo "$staged_ts" | xargs git add
      if ! (cd client && echo "$ts_files_rel" | xargs bunx oxlint --quiet 2>/dev/null); then
        echo "❌ oxlint ha trobat errors que no s'han pogut corregir automàticament."
        echo "   Executa 'make fmt-client' per veure els detalls."
        failed=1
      fi
    fi
  fi
fi

exit $failed
