#!/bin/bash

# Final gate before pushing: lint voting-contract/ (ruff) and client/ (oxlint + oxfmt)

failed=0

# --- Python (voting-contract/) ---
py_files=$(git ls-files 'voting-contract/*.py' 'voting-contract/**/*.py')

if [[ -n "$py_files" ]]; then
  if ! command -v ruff &>/dev/null; then
    echo "⚠️  ruff no trobat - saltant la comprovació de Python."
  else
    echo "🔍 Comprovació final de Python (ruff)..."
    if ! echo "$py_files" | xargs ruff check --quiet; then
      echo "❌ ruff ha trobat errors. Executa 'make fmt-contract' i torna a fer push."
      failed=1
    elif ! echo "$py_files" | xargs ruff format --check --quiet; then
      echo "❌ ruff format ha trobat diferències. Executa 'make fmt-contract' i torna a fer push."
      failed=1
    fi
  fi
fi

# --- TypeScript / JavaScript (client/) ---
if [[ -d "client" ]]; then
  ts_files=$(git ls-files 'client/*.ts' 'client/*.tsx' 'client/**/*.ts' 'client/**/*.tsx')
  if [[ -n "$ts_files" ]]; then
    if ! (cd client && bunx oxlint --version &>/dev/null 2>&1); then
      echo "⚠️  oxlint no trobat - saltant la comprovació de TypeScript."
    else
      echo "🔍 Comprovació final de TypeScript (oxlint + oxfmt)..."
      if ! (cd client && bun run check 2>/dev/null); then
        echo "❌ oxlint/oxfmt ha trobat errors. Executa 'make fmt-client' i torna a fer push."
        failed=1
      fi
    fi
  fi
fi

[[ $failed -eq 0 ]] && echo "✅ Tot correcte."
exit $failed
