{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"printWidth": 120,
	"tabWidth": 4,
	"useTabs": true,
	"semi": false,
	"singleQuote": true,
	"trailingComma": "none",
	"bracketSpacing": true,
	"jsxSingleQuote": false,
	"arrowParens": "avoid",
	"sortTailwindcss": {},
	"bracketSameLine": false,
	"endOfLine": "lf",
	"insertFinalNewline": true,
	"singleAttributePerLine": false,
	"sortImports": {
		"groups": ["type", "builtin", "external", "internal", "parent", ["sibling", "index"], "style", "unknown"],
		"newlinesBetween": true,
		"internalPattern": ["@/*"]
	},
	"ignorePatterns": ["node_modules", "dist", "build"]
}
