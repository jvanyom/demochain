# ── Token d'autenticació Algorand LocalNet ────────────────────────────────────
ALGO_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# ── Ports exposats al host ────────────────────────────────────────────────────
ALGOD_PORT=4001
KMD_PORT=4002
CLIENT_PORT=5173

# ── Ports interns dels contenidors ────────────────────────────────────────────
CLIENT_CONTAINER_PORT=5173
ALGOD_CONTAINER_PORT=8080
KMD_CONTAINER_PORT=7833

# ── Hostname intern de Docker (nom del servei dins la xarxa compose) ──────────
ALGOD_HOST=algod

# ── Adreces des del navegador (sempre apunten al host) ───────────────────────
VITE_ALGOD_SERVER=http://localhost
VITE_KMD_SERVER=http://localhost

# ── Wallet KMD ────────────────────────────────────────────────────────────────
KMD_WALLET_NAME=unencrypted-default-wallet
KMD_WALLET_PASSWORD=

# ── Indexer ───────────────────────────────────────────────────────────────────
INDEXER_PORT=8980

# ── Explorador de transaccions Algorand ───────────────────────────────────────
VITE_LORA_BASE=https://lora.algokit.io/localnet/transaction
