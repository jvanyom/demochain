# Adreça del NotaryContract desplegat
NOTARY_CONTRACT_ADDRESS=

# Clau privada de l'admin del NotaryContract (per al desplegament i la gestió)
NOTARY_ADMIN_PRIVATE_KEY=

# ── Credencials dels nodes universitaris ─────────────────────────────────────
UIB_ALGO_MNEMONIC=
UIB_ETH_PRIVATE_KEY=

UPC_ALGO_MNEMONIC=
UPC_ETH_PRIVATE_KEY=

UAB_ALGO_MNEMONIC=
UAB_ETH_PRIVATE_KEY=
