# ── Algorand (AlgoKit LocalNet per defecte) ───────────────────────────────────
ALGOD_SERVER=http://localhost
ALGOD_PORT=4001
ALGOD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# APP_ID del contracte Demochain desplegat
DEMOCHAIN_APP_ID=

# ── Ethereum ──────────────────────────────────────────────────────────────────
# URL RPC del node Ethereum (Hardhat local o Sepolia testnet)
ETHEREUM_RPC_URL=http://localhost:8545

# URL RPC del node Ethereum local (per a Hardhat localhost network)
ETHEREUM_LOCALHOST_URL=http://127.0.0.1:8545

# Adreça del NotaryContract desplegat
NOTARY_CONTRACT_ADDRESS=

# Límit de gas per a les transaccions al NotaryContract
ETH_GAS_LIMIT=200000

# Timeout en segons per esperar la confirmació d'una transacció Ethereum
ETH_TX_TIMEOUT=60

# Clau privada de l'admin del NotaryContract (per al desplegament i la gestió)
NOTARY_ADMIN_PRIVATE_KEY=

# ── Credencials dels nodes universitaris ─────────────────────────────────────
UIB_ALGO_MNEMONIC=
UIB_ETH_PRIVATE_KEY=

UPC_ALGO_MNEMONIC=
UPC_ETH_PRIVATE_KEY=

UAB_ALGO_MNEMONIC=
UAB_ETH_PRIVATE_KEY=
